@model int

<div class="container animate-fade-up">
    <div class="row justify-content-center mt-5">
        <div class="col-12 col-md-8 col-lg-6 text-center">

            <!-- Payment success icon -->
            <div class="mb-4">
                <i class="fa-solid fa-credit-card fa-4x" style="color:var(--color-accent);"></i>
            </div>

            <!-- Payment success message -->
            <div class="d-flex align-items-baseline gap-3 mb-3 justify-content-center">
                <span class="section-label">Payment Confirmed</span>
                <hr class="section-divider my-0" style="width:60px;">
            </div>
            <h1 class="section-title mb-3">Payment <em>Successful</em></h1>

            <!-- Order number display -->
            <p class="text-muted mb-1" style="font-family:var(--font-condensed);letter-spacing:0.08em;font-size:0.85rem;">
                ORDER NUMBER
            </p>
            <h3 class="fw-bold mb-4" style="color:var(--color-accent);">#@Model</h3>

            <p class="text-muted mb-5" style="font-size:0.9rem;">
                Your payment has been successfully processed. The order status has been updated accordingly.
            </p>

            <!-- Action buttons -->
            <div class="d-flex gap-3 justify-content-center flex-wrap">

                <!-- Navigates back to order list -->
                <a asp-area="Admin" asp-controller="Order" asp-action="Index"
                       class="btn btn-outline-dark px-4 py-2">
                    <i class="fa-solid fa-list me-2"></i>Back to Orders
                </a>

                <!-- Navigates to the paid order's detail page -->
                <a asp-area="Admin" asp-controller="Order" asp-action="Details"
                       asp-route-orderId="@Model"
                       class="btn btn-primary px-4 py-2">
                    <i class="fa-solid fa-receipt me-2"></i>View Order
                </a>

            </div>

        </div>
    </div>
</div>