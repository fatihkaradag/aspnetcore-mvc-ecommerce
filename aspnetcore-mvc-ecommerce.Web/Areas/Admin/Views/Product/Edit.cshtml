@model ProductVM

<form method="post" asp-action="Edit" asp-route-id="@Model.Product.Id">

    <!-- Breadcrumb navigation -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex align-items-baseline gap-3 mb-4">
        <span class="section-label">New Entry</span>
        <hr class="section-divider my-0">
    </div>
    <h1 class="section-title mb-5">Edit Product</h1>

    <!-- Hidden field sends product Id with the form POST -->
    <input asp-for="Product.Id" hidden />

    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card px-4 py-5 px-md-5">

                <!-- Title -->
                <div class="mb-4">
                    <label asp-for="Product.Title" class="form-label"></label>
                    <input asp-for="Product.Title" class="form-control" />
                    <span asp-validation-for="Product.Title" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Description -->
                <div class="mb-4">
                    <label asp-for="Product.Description" class="form-label"></label>
                    <!-- Textarea used for long-form description input -->
                    <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Product.Description" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Author -->
                <div class="mb-4">
                    <label asp-for="Product.Author" class="form-label"></label>
                    <input asp-for="Product.Author" class="form-control" />
                    <span asp-validation-for="Product.Author" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- ISBN -->
                <div class="mb-4">
                    <label asp-for="Product.ISBN" class="form-label"></label>
                    <input asp-for="Product.ISBN" class="form-control" />
                    <span asp-validation-for="Product.ISBN" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Category Dropdown — populated from ViewModel CategoryList -->
                <div class="mb-4">
                    <label asp-for="Product.CategoryId" class="form-label"></label>
                    <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select">
                        <option disabled value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="Product.CategoryId" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Price fields in a responsive grid -->
                <div class="row mb-4">

                    <!-- List Price -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.ListPrice" class="form-label"></label>
                        <input asp-for="Product.ListPrice" class="form-control" />
                        <span asp-validation-for="Product.ListPrice" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                    <!-- Price 1-50 -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.Price" class="form-label"></label>
                        <input asp-for="Product.Price" class="form-control" />
                        <span asp-validation-for="Product.Price" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                    <!-- Price 50+ -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.Price50" class="form-label"></label>
                        <input asp-for="Product.Price50" class="form-control" />
                        <span asp-validation-for="Product.Price50" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                    <!-- Price 100+ -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.Price100" class="form-label"></label>
                        <input asp-for="Product.Price100" class="form-control" />
                        <span asp-validation-for="Product.Price100" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                </div>

                <!-- Actions -->
                <div class="d-flex gap-3">
                    <!-- Back button navigates to Product list without updating -->
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                           class="btn btn-outline-dark flex-fill">
                        <i class="fa-solid fa-arrow-left fa-sm me-2"></i>Back
                    </a>
                    <!-- Submit button triggers form POST -->
                    <button type="submit" class="btn btn-primary flex-fill">
                        Update Product<i class="fa-solid fa-arrow-right fa-sm ms-2"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>

</form>

@section Scripts {
    @* Loads client-side validation scripts *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}