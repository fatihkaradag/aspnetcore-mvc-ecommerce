@model Product

<form method="post" asp-action="Delete" asp-route-id="@Model.Id">

    <!-- Breadcrumb navigation -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex align-items-baseline gap-3 mb-4">
        <span class="section-label">Danger Zone</span>
        <hr class="section-divider my-0">
    </div>
    <h1 class="section-title mb-5">Delete Product</h1>

    <!-- Hidden field sends product Id with the form POST -->
    <input asp-for="Id" hidden />

    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card px-4 py-5 px-md-5">

                <!-- Read-only Title field — disabled to prevent editing before delete -->
                <div class="mb-4">
                    <label asp-for="Title" class="form-label"></label>
                    <input asp-for="Title" class="form-control" disabled />
                </div>

                <!-- Read-only Author field — disabled to prevent editing before delete -->
                <div class="mb-4">
                    <label asp-for="Author" class="form-label"></label>
                    <input asp-for="Author" class="form-control" disabled />
                </div>

                <!-- Read-only ISBN field — disabled to prevent editing before delete -->
                <div class="mb-4">
                    <label asp-for="ISBN" class="form-label"></label>
                    <input asp-for="ISBN" class="form-control" disabled />
                </div>

                <!-- Read-only Price field — disabled to prevent editing before delete -->
                <div class="mb-5">
                    <label asp-for="Price" class="form-label"></label>
                    <input asp-for="Price" class="form-control" disabled />
                </div>

                <!-- Warning message to inform user this action is irreversible -->
                <div class="alert alert-warning mb-4" role="alert">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>
                    This action is <strong>irreversible</strong>. The product will be permanently deleted.
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3">
                    <!-- Back button navigates to Product list without deleting -->
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                           class="btn btn-outline-dark flex-fill">
                        <i class="fa-solid fa-arrow-left fa-sm me-2"></i>Back
                    </a>
                    <!-- Submit button triggers delete POST -->
                    <button type="submit" class="btn btn-danger flex-fill">
                        Delete Product<i class="fa-solid fa-arrow-right fa-sm ms-2"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>

</form>

@section Scripts {
    @* Loads client-side validation scripts *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}