@model ProductVM

<!-- Breadcrumb navigation — dynamically shows Create or Update based on product Id -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-area="Customer" asp-controller="Home" asp-action="Index">Home</a></li>
        <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Product" asp-action="Index">Products</a></li>
        <li class="breadcrumb-item active" aria-current="page">@(Model.Product.Id != 0 ? "Update" : "Create")</li>
    </ol>
</nav>

<form method="post" asp-area="Admin" asp-controller="Product" asp-action="Upsert" enctype="multipart/form-data">

    <!-- Hidden field sends product Id with the form POST — 0 means create, non-zero means update -->
    <input asp-for="Product.Id" hidden />
    <input asp-for="Product.ImageUrl" hidden/>

    <!-- Page Header — dynamically shows Create or Update -->
    <div class="d-flex align-items-baseline gap-3 mb-4">
        <span class="section-label">@(Model.Product.Id != 0 ? "Edit Entry" : "New Entry")</span>
        <hr class="section-divider my-0">
    </div>
    <h1 class="section-title mb-5">@(Model.Product.Id != 0 ? "Update Product" : "Create Product")</h1>

    <!-- Two-column layout — form fields on left, image preview on right -->
    <div class="row g-4">

        <!-- Left Column — Form Fields -->
        <div class="col-12 col-lg-8">
            <div class="card px-4 py-5 px-md-5">

                <!-- Title -->
                <div class="mb-4">
                    <label asp-for="Product.Title" class="form-label"></label>
                    <input asp-for="Product.Title" class="form-control" />
                    <span asp-validation-for="Product.Title" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Description — uses TinyMCE rich text editor -->
                <div class="mb-4">
                    <label asp-for="Product.Description" class="form-label"></label>
                    <textarea asp-for="Product.Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Product.Description" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Author -->
                <div class="mb-4">
                    <label asp-for="Product.Author" class="form-label"></label>
                    <input asp-for="Product.Author" class="form-control" />
                    <span asp-validation-for="Product.Author" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- ISBN -->
                <div class="mb-4">
                    <label asp-for="Product.ISBN" class="form-label"></label>
                    <input asp-for="Product.ISBN" class="form-control" />
                    <span asp-validation-for="Product.ISBN" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Category Dropdown — populated from ViewModel CategoryList -->
                <div class="mb-4">
                    <label asp-for="Product.CategoryId" class="form-label"></label>
                    <select asp-for="Product.CategoryId" asp-items="@Model.CategoryList" class="form-select">
                        <option disabled selected value="">-- Select Category --</option>
                    </select>
                    <span asp-validation-for="Product.CategoryId" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Price fields in a responsive grid -->
                <div class="row mb-4">

                    <!-- List Price -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.ListPrice" class="form-label"></label>
                        <input asp-for="Product.ListPrice" class="form-control" />
                        <span asp-validation-for="Product.ListPrice" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                    <!-- Price 1-50 -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.Price" class="form-label"></label>
                        <input asp-for="Product.Price" class="form-control" />
                        <span asp-validation-for="Product.Price" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                    <!-- Price 50+ -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.Price50" class="form-label"></label>
                        <input asp-for="Product.Price50" class="form-control" />
                        <span asp-validation-for="Product.Price50" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                    <!-- Price 100+ -->
                    <div class="col-12 col-md-3 mb-3 mb-md-0">
                        <label asp-for="Product.Price100" class="form-label"></label>
                        <input asp-for="Product.Price100" class="form-control" />
                        <span asp-validation-for="Product.Price100" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    </div>

                </div>

                <!-- Actions -->
                <div class="d-flex gap-3">
                    <!-- Back button navigates to Product list without saving -->
                    <a asp-area="Admin" asp-controller="Product" asp-action="Index"
                           class="btn btn-outline-dark flex-fill">
                        <i class="fa-solid fa-arrow-left fa-sm me-2"></i>Back
                    </a>
                    <!-- Submit button label changes based on create or update mode -->
                    <button type="submit" class="btn btn-primary flex-fill">
                        @(Model.Product.Id != 0 ? "Update Product" : "Create Product")
                        <i class="fa-solid fa-arrow-right fa-sm ms-2"></i>
                    </button>
                </div>

            </div>
        </div>

        <!-- Right Column — Image Upload and Preview -->
        <div class="col-12 col-lg-4">
            <div class="card px-4 py-5 px-md-4 h-100">

                <!-- Product Image Upload — accepts image files only -->
                <div class="mb-3">
                    <label asp-for="Product.ImageUrl" class="form-label"></label>
                    <input type="file" name="file" class="form-control border-0 shadow" accept="image/*" />
                </div>

                <!-- Image preview — shows existing image in edit mode -->
                @if (Model.Product.Id != 0 && !string.IsNullOrEmpty(Model.Product.ImageUrl))
                {
                    <div class="mt-3">
                        <p class="text-muted mb-2" style="font-size:0.75rem;font-family:var(--font-condensed);letter-spacing:0.08em;">
                            Current Image
                        </p>
                        <!-- Displays the current product image -->
                        <img src="@Model.Product.ImageUrl"
                             alt="@Model.Product.Title"
                             class="img-fluid rounded"
                             style="width:100%; object-fit:cover;" />
                    </div>
                }
                else
                {
                    <!-- Placeholder shown when no image is available -->
                    <div class="mt-3 d-flex align-items-center justify-content-center rounded"
                         style="width:100%; object-fit:contain;  background:var(--color-mid);">
                        <div class="text-center" style="color:var(--color-muted);">
                            <i class="fa-solid fa-image fa-2x mb-2"></i>
                            <p class="mb-0" style="font-size:0.75rem;font-family:var(--font-condensed);letter-spacing:0.08em;">
                                No image uploaded
                            </p>
                        </div>
                    </div>
                }

            </div>
        </div>

    </div>

</form>

@section Scripts {
    @* Initializes TinyMCE rich text editor for description textarea *@
    <script>
        tinymce.init({
            selector: 'textarea',
            plugins: [
                'anchor', 'autolink', 'charmap', 'codesample', 'emoticons',
                'link', 'lists', 'media', 'searchreplace', 'table',
                'visualblocks', 'wordcount'
            ],
            toolbar: 'undo redo | blocks fontfamily fontsize | bold italic underline strikethrough | link media table | align lineheight | numlist bullist indent outdent | emoticons charmap | removeformat',
            uploadcare_public_key: '52578f37f4ae41aa1951',
        });
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}