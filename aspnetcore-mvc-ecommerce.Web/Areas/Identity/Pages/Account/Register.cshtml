@page
@model RegisterModel
@{
    ViewData["Title"] = "Join Our Book Community";
}

<div class="container mt-5 mb-5">

    <!-- Delete Production -->
    <div class="alert alert-info d-flex flex-wrap gap-2 justify-content-center mb-4 border-0 shadow-sm rounded-4">
        <div class="w-100 text-center mb-1">
            <small class="fw-bold text-uppercase text-muted" style="font-size: 0.7rem;">
                <i class="fa-solid fa-code me-1"></i> Developer QuickFill (Remove in Production)
            </small>
        </div>
        
        <button type="button" class="btn btn-sm btn-dark rounded-pill px-3" onclick="quickFill('admin@example.com', 'Admin123!', 'Admin')">
            <i class="fa-solid fa-user-shield me-1"></i> Admin
        </button>
        
        <button type="button" class="btn btn-sm btn-info text-white rounded-pill px-3" onclick="quickFill('employee@example.com', 'Employee123!', 'Employee')">
            <i class="fa-solid fa-user-tie me-1"></i> Employee
        </button>

        <button type="button" class="btn btn-sm btn-outline-primary rounded-pill px-3" onclick="quickFill('company@example.com', 'Company123!', 'Company')">
            <i class="fa-solid fa-building me-1"></i> Company
        </button>

        <button type="button" class="btn btn-sm btn-secondary rounded-pill px-3" onclick="quickFill('test@example.com', 'Test123!', 'Customer')">
            <i class="fa-solid fa-user me-1"></i> Customer
        </button>
    </div>

    <div class="row justify-content-center shadow-lg rounded-4 overflow-hidden bg-white">
        
        <div class="col-lg-4 d-none d-lg-flex bg-primary align-items-center justify-content-center text-white p-5"
             style="background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);">
            <div class="text-center">
                <i class="fa-solid fa-book-bookmark fa-5x mb-4"></i>
                <h2 class="display-6 fw-bold">Reading Starts Here</h2>
                <p class="lead small">Create an account to access exclusive deals and your personal library.</p>
                <div class="mt-4 text-start">
                    <p class="small mb-2"><i class="fa-solid fa-truck-fast me-2 text-warning"></i> Fast shipping for members</p>
                    <p class="small mb-2"><i class="fa-solid fa-heart me-2 text-danger"></i> Save your favorite authors</p>
                </div>
            </div>
        </div>

        <div class="col-lg-8 p-4 p-md-5">
            <div class="text-center mb-4">
                <h1 class="h3 fw-bold text-dark">@ViewData["Title"]</h1>
                <p class="text-muted small">Enter your details to register</p>
            </div>

            <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger small" role="alert"></div>

                <p class="text-muted small fw-bold mb-2 border-bottom pb-1 text-uppercase">Account Details</p>
                <div class="row">
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Name" class="form-control border-0 border-bottom rounded-0" placeholder="Full Name" />
                            <label asp-for="Input.Name"><i class="fa-solid fa-user me-2"></i>Full Name</label>
                            <span asp-validation-for="Input.Name" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control border-0 border-bottom rounded-0" autocomplete="username" placeholder="name@example.com" />
                            <label asp-for="Input.Email"><i class="fa-solid fa-envelope me-2"></i>Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>
                    </div>
                    
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control border-0 border-bottom rounded-0" autocomplete="new-password" placeholder="Password" />
                            <label asp-for="Input.Password"><i class="fa-solid fa-lock me-2"></i>Password</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.ConfirmPassword" class="form-control border-0 border-bottom rounded-0" autocomplete="new-password" placeholder="Confirm" />
                            <label asp-for="Input.ConfirmPassword"><i class="fa-solid fa-shield-check me-2"></i>Confirm Password</label>
                        </div>
                    </div>
                </div>

                <p class="text-muted small fw-bold mt-3 mb-2 border-bottom pb-1 text-uppercase">Shipping Information</p>
                <div class="row">
                    <div class="col-12">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.StreetAddress" class="form-control border-0 border-bottom rounded-0" placeholder="Street" />
                            <label asp-for="Input.StreetAddress"><i class="fa-solid fa-map-location-dot me-2"></i>Street Address</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.City" class="form-control border-0 border-bottom rounded-0" placeholder="City" />
                            <label asp-for="Input.City">City</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.State" class="form-control border-0 border-bottom rounded-0" placeholder="State" />
                            <label asp-for="Input.State">State / Region</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.PostalCode" class="form-control border-0 border-bottom rounded-0" placeholder="Postal" />
                            <label asp-for="Input.PostalCode">Postal Code</label>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-floating mb-3">
                            <input asp-for="Input.PhoneNumber" class="form-control border-0 border-bottom rounded-0" placeholder="Phone" />
                            <label asp-for="Input.PhoneNumber"><i class="fa-solid fa-phone me-2"></i>Phone Number</label>
                        </div>
                    </div>
                </div>

                <!-- @if (User.IsInRole("Admin")){} -->
                    <div class="mb-4 mt-2">
                        <label class="small text-muted mb-1">System Role</label>
                        <select asp-for="Input.Role" asp-items="@Model.Input.RoleList" class="form-select border-0 border-bottom rounded-0 bg-light">
                            <option disabled selected value="">-- Select Role --</option>
                        </select>
                    </div>

                    <div class="mb-4 mt-2 companyDiv">
                        <label class="small text-muted mb-1">Company List</label>
                        <select asp-for="Input.CompanyId" style="display:none;" asp-items="@Model.Input.CompanyList" class="form-select border-0 border-bottom rounded-0 bg-light">
                            <option disabled selected value="">-- Select Company --</option>
                        </select>
                    </div>
                

                <button id="registerSubmit" type="submit" class="w-100 btn btn-lg btn-primary rounded-pill shadow-sm mt-4 py-3 fw-bold text-uppercase">
                    Create My Account
                </button>

                <div class="text-center mt-4">
                    <div class="d-flex align-items-center mb-3">
                        <hr class="flex-grow-1 border-secondary opacity-25">
                        <span class="px-3 text-muted small fw-bold">OR QUICK REGISTER WITH</span>
                        <hr class="flex-grow-1 border-secondary opacity-25">
                    </div>
                    <div class="d-flex justify-content-center gap-3">
                        <button type="button" class="btn btn-outline-danger border-2 rounded-pill px-4 py-2 d-flex align-items-center shadow-sm">
                            <i class="fa-brands fa-google me-2"></i> Google
                        </button>
                        <button type="button" class="btn btn-outline-primary border-2 rounded-pill px-4 py-2 d-flex align-items-center shadow-sm">
                            <i class="fa-brands fa-facebook-f me-2"></i> Facebook
                        </button>
                    </div>
                </div>

                <p class="text-center text-muted small mt-4">
                    Already a member? <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="text-primary fw-bold text-decoration-none">Login here</a>
                </p>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function quickFill(email, pass, role) {
            $('#Input_Name').val(role + " User");
            $('#Input_Email').val(email);
            $('#Input_Password').val(pass);
            $('#Input_ConfirmPassword').val(pass);

            $('#Input_StreetAddress').val("123 Tech Avenue");
            $('#Input_City').val("Istanbul");
            $('#Input_State').val("TR");
            $('#Input_PostalCode').val("34000");
            $('#Input_PhoneNumber').val("5551112233");

            $('#Input_Role').val(role).change();

            if (role === 'Company') {
                setTimeout(function() {
                    $('#Input_CompanyId option:eq(1)').prop('selected', true);
                }, 100);
            }
        }

        $(document).ready(function() {

                
            function toggleCompanyDropdown() {
                if ($('#Input_Role').val() === 'Company') {
                    $('#Input_CompanyId').show();
                } else {
                    $('#Input_CompanyId').hide();
                    $('#Input_CompanyId').val('');
                }
            }
            $('#Input_Role').change(toggleCompanyDropdown);
            toggleCompanyDropdown();
        });
    </script>
}