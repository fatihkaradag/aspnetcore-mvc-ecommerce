@model ShoppingCartVM

<form method="post">
    <div class="container animate-fade-up">

        <!-- Page header -->
        <div class="mb-5 mt-4">
            <span class="section-label">Your Selection</span>
            <h1 class="section-title">Shopping <em>Basket</em></h1>
        </div>

        <div class="card border-0 bg-transparent">

            <!-- Cart header with continue shopping button -->
            <div class="card-header bg-ink text-light py-4 rounded-top border-0">
                <div class="row px-2 px-md-4 align-items-center">
                    <div class="col-6">
                        <h5 class="mb-0 text-white fw-serif italic" style="text-transform:none;font-size:1.4rem;">
                            My Library
                        </h5>
                    </div>
                    <div class="col-6 text-end">
                        <!-- Navigates back to product listing -->
                        <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                               class="btn btn-outline-light btn-sm tracking-wide">
                            <i class="bi bi-arrow-left me-1"></i> CONTINUE SHOPPING
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body bg-cream shadow-card py-5">
                <div class="row px-md-4">
                    <div class="col-12">

                        @if (!Model.ShoppingCartList.Any())
                        {
                            <!-- Empty cart state — shown when no items are in the cart -->
                            <div class="text-center py-5">
                                <i class="fa-solid fa-cart-shopping fa-3x mb-3" style="color:var(--color-muted);"></i>
                                <p class="text-muted" style="font-family:var(--font-condensed);letter-spacing:0.08em;">
                                    Your basket is empty.
                                </p>
                                <a asp-area="Customer" asp-controller="Home" asp-action="Index"
                                       class="btn btn-primary mt-2">
                                    Browse Books
                                </a>
                            </div>
                        }
                        else
                        {
                            <!-- Cart items list -->
                            @foreach (var item in Model.ShoppingCartList)
                            {
                                <div class="row border-bottom pb-4 mb-4 align-items-center">

                                    <!-- Product cover image — hidden on mobile -->
                                    <div class="d-none d-lg-block col-lg-2 text-center">
                                        <div class="book-cover shadow-xs mx-auto" style="width:100px;height:150px;">
                                            <img src="@item.Product?.ImageUrl"
                                                 class="img-fluid h-100"
                                                 style="object-fit:contain;"
                                                 alt="@item.Product?.Title" />
                                        </div>
                                    </div>

                                    <!-- Product title, author and description -->
                                    <div class="col-12 col-lg-5 pt-3 pt-lg-0 text-center text-lg-start">
                                        <h5 class="text-ink fw-serif mb-1" style="font-size:1.25rem;">
                                            @item.Product?.Title
                                        </h5>
                                        <p class="text-muted-warm italic mb-2">@item.Product?.Author</p>
                                        <!-- Description rendered as HTML — sanitize if user-generated -->
                                        <div class="text-brown d-none d-md-block" style="font-size:0.85rem;">
                                            @Html.Raw(item.Product?.Description)
                                        </div>
                                    </div>

                                    <!-- Price, quantity controls and remove button -->
                                    <div class="col-12 col-lg-5">
                                        <div class="row align-items-center">

                                            <!-- Price per unit based on quantity tier -->
                                            <div class="col-4 text-center">
                                                <h6 class="price text-ink mb-0">
                                                    @item.Price.ToString("c")
                                                    <span class="text-muted-warm d-block" style="font-size:0.7rem;">per copy</span>
                                                </h6>
                                            </div>

                                            <!-- Quantity increment and decrement controls -->
                                            <div class="col-5 text-center">
                                                <div class="btn-group shadow-xs" role="group">
                                                    <!-- Decrease quantity or remove if quantity is 1 -->
                                                    <a asp-area="Customer" asp-controller="Cart"
                                                           asp-action="Minus" asp-route-cartId="@item.Id"
                                                           class="btn btn-outline-dark py-2 px-3">
                                                        <i class="fa-solid fa-minus fa-xs"></i>
                                                    </a>
                                                    <span class="btn btn-light border-dark border-start-0 border-end-0 fw-bold px-3">
                                                        @item.Quantity
                                                    </span>
                                                    <!-- Increase quantity -->
                                                    <a asp-area="Customer" asp-controller="Cart"
                                                           asp-action="Plus" asp-route-cartId="@item.Id"
                                                           class="btn btn-outline-dark py-2 px-3">
                                                        <i class="fa-solid fa-plus fa-xs"></i>
                                                    </a>
                                                </div>
                                            </div>

                                            <!-- Remove item from cart entirely -->
                                            <div class="col-3 text-end">
                                                <a asp-area="Customer" asp-controller="Cart"
                                                       asp-action="Remove" asp-route-cartId="@item.Id"
                                                       class="btn btn-outline-danger border-0">
                                                    <i class="fa-solid fa-trash fa-xs"></i>
                                                </a>
                                            </div>

                                        </div>
                                    </div>
                                </div>
                            }
                        }

                    </div>
                </div>
            </div>

            <!-- Order summary and checkout section -->
            <div class="card-footer bg-parchment border-top border-muted-warm py-5 mt-2">
                <div class="row align-items-center">
                    <div class="col-md-6 offset-md-3">
                        <div class="bg-cream p-4 rounded shadow-xs border border-muted-warm">

                            <!-- Subtotal row -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="form-label mb-0">Subtotal</span>
                                <span class="price text-brown">@Model.OrderHeader.OrderTotal.ToString("c")</span>
                            </div>

                            <!-- Shipping row — free shipping -->
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="form-label mb-0">Shipping</span>
                                <span class="text-success italic fw-semibold" style="font-size:0.8rem;">
                                    Complimentary
                                </span>
                            </div>

                            <hr class="section-divider">

                            <!-- Estimated total -->
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="text-ink fw-serif mb-0">ESTIMATED TOTAL</h5>
                                <h4 class="price-sale mb-0 fs-3">@Model.OrderHeader.OrderTotal.ToString("c")</h4>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Checkout button -->
                <div class="row mt-4">
                    <div class="col-md-4 offset-md-4 text-center">
                        <a asp-area="Customer" asp-controller="Cart" asp-action="Summary"
                               class="btn btn-warning w-100 py-3 shadow-lift fw-bold tracking-wider">
                            PROCEED TO SUMMARY <i class="bi bi-chevron-right ms-2"></i>
                        </a>
                        <p class="mt-3 text-muted-warm italic" style="font-size:0.75rem;">
                            Secure Checkout Powered by Editorial Pay
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</form>