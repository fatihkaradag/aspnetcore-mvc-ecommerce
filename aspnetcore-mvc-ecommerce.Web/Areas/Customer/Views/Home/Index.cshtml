@model IEnumerable<Product>

@if (!Model.Any())
{
    <!-- Empty state — shown when no products are available -->
    <div class="text-center py-5">
        <i class="fa-solid fa-box-open fa-3x mb-3" style="color:var(--color-muted);"></i>
        <p style="color:var(--color-muted);font-family:var(--font-condensed);letter-spacing:0.08em;">No products available.</p>
    </div>
}
else
{
    <!-- Product grid — displays all available products in a responsive layout -->
    <div class="row g-4 pb-3">
        @foreach (var product in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 col-12">
                <div class="card border-0 shadow-sm h-100 rounded overflow-hidden">

                    <!-- Product image — links to detail page -->
                    <a asp-action="Details" asp-route-productId="@product.Id" class="d-block overflow-hidden" style="height:280px;">
                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                        {
                            <!-- Displays product cover image -->
                            <img src="@product.ImageUrl"
                                 alt="@product.Title"
                                 class="img-fluid w-100 h-100"
                                 style="object-fit:contain; background:var(--color-mid);" />
                        }
                        else
                        {
                            <!-- Placeholder shown when no image is available -->
                            <div class="w-100 h-100 d-flex align-items-center justify-content-center"
                                 style="background:var(--color-mid);">
                                <i class="fa-solid fa-book fa-3x" style="color:var(--color-muted);"></i>
                            </div>
                        }
                    </a>

                    <div class="card-body d-flex flex-column justify-content-between">

                        <div>
                            <!-- Product title -->
                            <p class="card-title h6 text-uppercase text-center mb-1" style="color:var(--color-white);">
                                @product.Title
                            </p>

                            <!-- Product author -->
                            <p class="text-center mb-3" style="color:var(--color-muted);font-size:0.82rem;">
                                by <strong>@product.Author</strong>
                            </p>
                        </div>

                        <div>
                            <!-- List price with strikethrough — shows original price -->
                            <p class="text-center mb-0" style="font-size:0.82rem;color:var(--color-muted);">
                                List Price:
                                <span class="text-decoration-line-through">
                                    @product.ListPrice.ToString("c")
                                </span>
                            </p>

                            <!-- Lowest available price — shown as a deal indicator -->
                            <p class="text-center mb-3" style="font-size:0.9rem;color:var(--color-accent);font-weight:700;">
                                As low as: @product.Price100.ToString("c")
                            </p>

                            <!-- Details button — navigates to product detail page -->
                            <a asp-action="Details"
                                   asp-route-productId="@product.Id"
                                   class="btn btn-primary w-100">
                                View Details <i class="fa-solid fa-arrow-right fa-sm ms-1"></i>
                            </a>
                        </div>

                    </div>
                </div>
            </div>
        }
    </div>
}