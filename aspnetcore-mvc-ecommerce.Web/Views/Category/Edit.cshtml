@model Category

<form method="post" asp-action="Edit" asp-route-id="@Model.Id">

    <!-- Breadcrumb -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-controller="Category" asp-action="Index">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex align-items-baseline gap-3 mb-4">
        <span class="section-label">New Entry</span>
        <hr class="section-divider my-0">
    </div>
    <h1 class="section-title mb-5">Edit Category</h1>

    <!-- Form Card -->

    <input asp-for="Id" hidden />

    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card px-4 py-5 px-md-5">

                <!-- Name -->
                <div class="mb-4">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name"
                           class="form-control"
                           placeholder="e.g. Jackets, Accessories…" />
                    <span asp-validation-for="Name" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                </div>

                <!-- Display Order -->
                <div class="mb-5">
                    <label asp-for="DisplayOrder" class="form-label"></label>
                    <input asp-for="DisplayOrder"
                           class="form-control"
                           placeholder="e.g. 1, 2, 3…" />
                    <span asp-validation-for="DisplayOrder" class="text-danger" style="font-size:0.78rem;font-family:var(--font-condensed);letter-spacing:0.05em;"></span>
                    <div class="mt-1" style="font-size:0.75rem;color:var(--color-muted);font-family:var(--font-condensed);letter-spacing:0.08em;">
                        Lower numbers appear first in the listing.
                    </div>
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3">
                    <a asp-controller="Category" asp-action="Index"
                           class="btn btn-outline-dark flex-fill">
                        <i class="fa-solid fa-arrow-left fa-sm me-2"></i>Back
                    </a>
                    <button type="submit" class="btn btn-primary flex-fill">
                        Update Category<i class="fa-solid fa-arrow-right fa-sm ms-2"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>

</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
