@using Microsoft.AspNetCore.Identity

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager


<ul class="navbar-nav">
    @if (SignInManager.IsSignedIn(User))
    {
        <!-- User dropdown (signed in) -->
        <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2"
                   data-bs-toggle="dropdown" href="#"
                   role="button" aria-haspopup="true" aria-expanded="false"
                   style="padding-left:0.4rem !important;">
                <span class="d-flex align-items-center justify-content-center"
                      style="width:30px;height:30px;border-radius:50%;
                    background:var(--c-parchment);
                    border:1.5px solid var(--c-border-dk);
                    font-size:0.75rem;color:var(--c-brown);">
                    <i class="fa-regular fa-user"></i>
                </span>
                <span class="d-none d-lg-inline"
                      style="font-size:0.8rem;color:var(--c-brown);font-weight:500;">
                    @UserManager.GetUserName(User)
                </span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
                <li>
                    <span class="dropdown-item-text"
                          style="font-size:0.72rem;color:var(--c-tan);
                        font-style:italic;padding:0.5rem 1rem 0.1rem;">
                        Hello,
                    </span>
                </li>
                <li>
                    <span class="dropdown-item-text"
                          style="font-family:var(--font-serif);font-weight:600;
                        font-size:0.9rem;color:var(--c-ink);
                        padding:0 1rem 0.5rem;">
                        @UserManager.GetUserName(User)
                    </span>
                </li>
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item" asp-area="Identity" asp-page="/Account/Manage/Index">
                        <i class="fa-regular fa-user fa-fw me-2" style="color:var(--c-tan);"></i>Profile
                    </a>
                </li>
                <li>
                    <a class="dropdown-item" asp-area="Admin" asp-controller="Order" asp-action="Index">
                        <i class="fa-solid fa-box fa-fw me-2" style="color:var(--c-tan);"></i>Order Management
                    </a>
                </li>
                @if (User.IsInRole(SD.Role_Admin) || User.IsInRole(SD.Role_Employee))
                {
                <li>
                    <a class="dropdown-item" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <i class="fa-solid fa-sliders fa-fw me-2" style="color:var(--c-tan);"></i>Admin Panel
                    </a>
                </li>
                }
                <li><hr class="dropdown-divider"></li>
                <li>
                    <form id="logoutForm"
                          asp-area="Identity"
                          asp-page="/Account/Logout"
                          asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                        <button type="submit" class="dropdown-item border-0 bg-transparent w-100 text-start"
                                style="color:var(--c-danger) !important;">
                            <i class="fa-solid fa-arrow-right-from-bracket fa-fw me-2"></i>Logout
                        </button>
                    </form>
                </li>
            </ul>
        </li>
    }
    else
    {
        <!-- Guest links -->
        <li class="nav-item">
            <a class="nav-link text-dark" id="register"
               asp-area="Identity" asp-page="/Account/Register">Register</a>
        </li>
        <li class="nav-item">
            <a class="nav-link text-dark" id="login"
               asp-area="Identity" asp-page="/Account/Login">Login</a>
        </li>
    }
</ul>