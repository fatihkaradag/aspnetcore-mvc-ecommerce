@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — MVC-Ecommerce</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css"
          integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw=="
          crossorigin="anonymous" referrerpolicy="no-referrer" />
    <link rel="stylesheet" href="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="//cdn.datatables.net/2.3.7/css/dataTables.dataTables.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- ===== TOP BAR ===== -->
    <div style="background-color:var(--c-ink);color:var(--c-tan);text-align:center;
        padding:0.45rem 1rem;font-family:var(--font-body);font-size:0.72rem;
        font-weight:500;letter-spacing:0.06em;">
        <i class="fa-solid fa-truck-fast me-2" style="color:var(--c-accent);font-size:0.65rem;"></i>
        Free shipping on orders over ₺500 &nbsp;·&nbsp;
        <a href="#" style="color:var(--c-accent);text-decoration:underline;text-underline-offset:2px;">Browse deals</a>
    </div>

    <!-- ===== NAVBAR ===== -->
    <header>
        <nav class="navbar navbar-expand-lg">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand" asp-area="Customer" asp-controller="Home" asp-action="Index">
                    <em>MVC</em><span>Ecommerce</span>
                </a>

                <!-- Mobile toggler -->
                <button class="navbar-toggler" type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar"
                        aria-controls="mainNavbar"
                        aria-expanded="false"
                        aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- Nav links -->
                <div class="collapse navbar-collapse justify-content-end" id="mainNavbar">
                    <ul class="navbar-nav align-items-lg-center gap-lg-1">

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Customer" asp-controller="Home" asp-action="Index">
                                Home
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-area="Customer" asp-controller="Home" asp-action="Privacy">
                                Privacy
                            </a>
                        </li>

                        <!-- Divider (desktop only) -->
                        <li class="nav-item d-none d-lg-flex align-items-center">
                            <span style="width:1px;height:16px;background:var(--c-border-dk);
                            display:inline-block;margin:0 0.4rem;"></span>
                        </li>

                        <!-- Inline Search (desktop only) -->
                        <li class="nav-item d-none d-lg-block">
                            <div style="position:relative;">
                                <input type="text"
                                       placeholder="Search books, authors…"
                                       style="font-family:var(--font-body);font-size:0.78rem;
                                background:var(--c-parchment);border:1.5px solid var(--c-border);
                                border-radius:999px;padding:0.38rem 2.2rem 0.38rem 1rem;
                                color:var(--c-ink);width:200px;outline:none;
                                transition:border-color 0.22s, width 0.3s;font-style:italic;"
                                       onfocus="this.style.borderColor='var(--c-accent)';this.style.width='240px'"
                                       onblur="this.style.borderColor='var(--c-border)';this.style.width='200px'" />
                                <i class="fa-solid fa-magnifying-glass"
                                   style="position:absolute;right:0.75rem;top:50%;
                                transform:translateY(-50%);color:var(--c-tan);
                                font-size:0.68rem;pointer-events:none;"></i>
                            </div>
                        </li>


                        <!-- Cart icon with live count from ShoppingCart view component -->
                        <li class="nav-item">
                            <a class="nav-link position-relative" title="Cart"
                                   asp-area="Customer" asp-controller="Cart" asp-action="Index"
                                   style="padding-left:0.6rem !important;padding-right:0.6rem !important;">

                                <i class="fa-solid fa-cart-shopping" style="font-size:1rem;"></i>

                                <span class="position-absolute top-5 start-70 translate-middle badge rounded-pill"
                                      style="background:var(--c-accent);font-size:0.52rem;
                                    padding:0.22em 0.42em;font-family:var(--font-body);">
                                    @await Component.InvokeAsync("ShoppingCart")
                                </span>

                            </a>
                        </li>
                            
                           

                        <partial name="_LoginPartial"/>


                    </ul>
                </div>

            </div>
        </nav>
    </header>
    <!-- ===== END NAVBAR ===== -->
    <!-- ===== MAIN CONTENT ===== -->
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <!-- ===== END MAIN CONTENT ===== -->
    <!-- ===== FOOTER ===== -->
    <footer class="footer">
        <div class="container">

            <!-- Main footer grid -->
            <div class="row gy-4 pb-4"
                 style="border-bottom:1px solid rgba(255,255,255,0.08);">

                <!-- Brand -->
                <div class="col-12 col-md-4">
                    <div style="font-family:var(--font-display);font-size:1.6rem;
                        font-style:italic;color:var(--c-cream);
                        letter-spacing:0.02em;margin-bottom:0.75rem;">
                        <em style="color:var(--c-cream);">MVC</em><span style="font-style:normal;color:var(--c-accent);">Ecommerce</span>
                    </div>
                    <p style="font-size:0.82rem;color:var(--c-tan);line-height:1.65;
                        max-width:260px;margin:0;font-style:italic;">
                        Curated books for curious minds. Discover your next favourite read.
                    </p>
                </div>

                <!-- Explore -->
                <div class="col-6 col-md-2">
                    <p style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;
                        text-transform:uppercase;color:var(--c-tan);margin-bottom:0.75rem;">
                        Explore
                    </p>
                    <ul style="list-style:none;padding:0;margin:0;
                        display:flex;flex-direction:column;gap:0.4rem;">
                        <li><a href="#" style="font-size:0.82rem;">New Arrivals</a></li>
                        <li><a href="#" style="font-size:0.82rem;">Bestsellers</a></li>
                        <li><a href="#" style="font-size:0.82rem;">Staff Picks</a></li>
                        <li><a href="#" style="font-size:0.82rem;">Deals &amp; Offers</a></li>
                    </ul>
                </div>

                <!-- Help -->
                <div class="col-6 col-md-2">
                    <p style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;
                        text-transform:uppercase;color:var(--c-tan);margin-bottom:0.75rem;">
                        Help
                    </p>
                    <ul style="list-style:none;padding:0;margin:0;
                        display:flex;flex-direction:column;gap:0.4rem;">
                        <li><a href="#" style="font-size:0.82rem;">FAQ</a></li>
                        <li><a href="#" style="font-size:0.82rem;">Shipping</a></li>
                        <li><a href="#" style="font-size:0.82rem;">Returns</a></li>
                        <li><a href="#" style="font-size:0.82rem;">Contact</a></li>
                    </ul>
                </div>

                <!-- Social -->
                <div class="col-12 col-md-4">
                    <p style="font-size:0.68rem;font-weight:600;letter-spacing:0.1em;
                        text-transform:uppercase;color:var(--c-tan);margin-bottom:0.75rem;">
                        Follow Us
                    </p>
                    <div class="d-flex gap-3 mb-3">
                        <a href="#"
                               style="width:34px;height:34px;border-radius:50%;
                            border:1px solid rgba(255,255,255,0.12);display:flex;
                            align-items:center;justify-content:center;
                            color:var(--c-tan);font-size:0.8rem;transition:all 0.2s;"
                               onmouseover="this.style.borderColor='var(--c-accent)';this.style.color='var(--c-accent)'"
                               onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='var(--c-tan)'">
                            <i class="fa-brands fa-instagram"></i>
                        </a>
                        <a href="#"
                               style="width:34px;height:34px;border-radius:50%;
                            border:1px solid rgba(255,255,255,0.12);display:flex;
                            align-items:center;justify-content:center;
                            color:var(--c-tan);font-size:0.8rem;transition:all 0.2s;"
                               onmouseover="this.style.borderColor='var(--c-accent)';this.style.color='var(--c-accent)'"
                               onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='var(--c-tan)'">
                            <i class="fa-brands fa-tiktok"></i>
                        </a>
                        <a href="#"
                               style="width:34px;height:34px;border-radius:50%;
                            border:1px solid rgba(255,255,255,0.12);display:flex;
                            align-items:center;justify-content:center;
                            color:var(--c-tan);font-size:0.8rem;transition:all 0.2s;"
                               onmouseover="this.style.borderColor='var(--c-accent)';this.style.color='var(--c-accent)'"
                               onmouseout="this.style.borderColor='rgba(255,255,255,0.12)';this.style.color='var(--c-tan)'">
                            <i class="fa-brands fa-goodreads"></i>
                        </a>
                    </div>
                    <p style="font-size:0.75rem;color:var(--c-tan);
                        font-style:italic;margin:0;line-height:1.5;">
                        Join our reading community and get weekly picks in your inbox.
                    </p>
                </div>

            </div>

            <!-- Bottom bar -->
            <div class="d-flex flex-column flex-md-row align-items-center
                justify-content-between gap-2 pt-4">
                <span style="font-size:0.75rem;color:var(--c-tan);">
                    &copy; 2026 MVC-Ecommerce &mdash; All rights reserved
                    <i class="fa-solid fa-heart ms-1" style="color:var(--c-accent);"></i>
                </span>
                <div class="d-flex gap-3">
                    <a href="#" style="font-size:0.72rem;">Privacy Policy</a>
                    <a href="#" style="font-size:0.72rem;">Terms of Use</a>
                    <a asp-area="Customer" asp-controller="Home" asp-action="Privacy"
                       style="font-size:0.72rem;">About</a>
                </div>
            </div>

        </div>
    </footer>
    <!-- ===== END FOOTER ===== -->


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="//cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.tiny.cloud/1/ligvy46rq39i3t9tacc8gi46seo8i3xqa9aui1kr1lsn788s/tinymce/8/tinymce.min.js" referrerpolicy="origin" crossorigin="anonymous"></script>
    <script src="//cdn.datatables.net/2.3.7/js/dataTables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <partial name="_Notification" />

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>
