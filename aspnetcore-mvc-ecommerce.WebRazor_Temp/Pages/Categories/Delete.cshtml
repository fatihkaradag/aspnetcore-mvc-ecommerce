@page
@model aspnetcore_mvc_ecommerce.WebRazor_Temp.Pages.Categories.DeleteModel


<form method="post" asp-action="Delete" asp-route-id="Category.Id">

    <!-- Breadcrumb navigation -->
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-page="/Index">Home</a></li>
            <li class="breadcrumb-item"><a asp-page="/Categories/Index">Categories</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
        </ol>
    </nav>

    <!-- Page Header -->
    <div class="d-flex align-items-baseline gap-3 mb-4">
        <span class="section-label">Danger Zone</span>
        <hr class="section-divider my-0">
    </div>
    <h1 class="section-title mb-5">Delete Category</h1>

    <!-- Form Card -->
    <!-- Hidden field sends category Id with the form POST -->
    <input asp-for="Category.Id" hidden />

    <div class="row justify-content-center">
        <div class="col-12">
            <div class="card px-4 py-5 px-md-5">

                <div class="mb-4">
                    <label asp-for="Category.Name" class="form-label"></label>
                    <input asp-for="Category.Name"
                           class="form-control"
                           placeholder="e.g. Jackets, Accessories…"
                           disabled />
                </div>

                <div class="mb-5">
                    <label asp-for="Category.DisplayOrder" class="form-label"></label>
                    <input asp-for="Category.DisplayOrder"
                           class="form-control"
                           placeholder="e.g. 1, 2, 3…"
                           disabled />
                </div>

                <div class="alert alert-warning mb-4" role="alert">
                    <i class="fa-solid fa-triangle-exclamation me-2"></i>
                    This action is <strong>irreversible</strong>. The category will be permanently deleted.
                </div>

                <!-- Actions -->
                <div class="d-flex gap-3">
                    <a asp-page="/Categories/Index"
                           class="btn btn-outline-dark flex-fill">
                        <i class="fa-solid fa-arrow-left fa-sm me-2"></i>Back
                    </a>
                    <button type="submit" class="btn btn-danger flex-fill">
                        Delete Category<i class="fa-solid fa-arrow-right fa-sm ms-2"></i>
                    </button>
                </div>

            </div>
        </div>
    </div>

</form>
